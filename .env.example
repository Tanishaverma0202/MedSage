# ============================================================================
# MedSage Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your actual values
# Do NOT commit .env to version control

# ============================================================================
# Server Configuration
# ============================================================================
NODE_ENV=production
PORT=3000

# ============================================================================
# Database Configuration
# ============================================================================
# For MongoDB Atlas (Recommended for Production):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/medsage

# For Local MongoDB:
# MONGODB_URI=mongodb://localhost:27017/medsage

# For Docker Compose:
# MONGODB_URI=mongodb://admin:password@mongodb:27017/medsage?authSource=admin

MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/medsage

# ============================================================================
# Redis Configuration (for caching and job queue)
# ============================================================================
# Cloud Redis:
# REDIS_URL=redis://:password@redis-host:6379

# Local Redis:
# REDIS_URL=redis://localhost:6379

# Docker Compose:
# REDIS_URL=redis://redis:6379

REDIS_URL=redis://localhost:6379

# ============================================================================
# AI Configuration
# ============================================================================
# Get API key from: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=your_google_generative_ai_key_here

# ============================================================================
# JWT Configuration
# ============================================================================
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ============================================================================
# Email Service Configuration
# ============================================================================
# Gmail setup: https://support.google.com/accounts/answer/185833?hl=en
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password
EMAIL_FROM=noreply@medsage.com

# ============================================================================
# Frontend Configuration
# ============================================================================
# URL where frontend is hosted (for CORS)
FRONTEND_URL=http://localhost:5173
# Or for production: https://your-frontend-domain.com

# API URL for frontend (internal)
VITE_API_URL=http://localhost:3000

# ============================================================================
# Rate Limiting Configuration
# ============================================================================
RATE_LIMIT_WINDOW_MS=15000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=debug
# Options: error, warn, info, debug, trace

# ============================================================================
# Optional: Additional Configurations
# ============================================================================
# Application Name
APP_NAME=MedSage

# Application Version
APP_VERSION=1.0.0

# Enable/Disable Features
ENABLE_AI_FEATURES=true
ENABLE_REPORTS=true
ENABLE_DISCUSSIONS=true
